{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "RDSL",
    "scopeName": "source.rdsl",
    "patterns": [
        { "include": "#comments" },
        { "include": "#numbers" },
        { "include": "#symbols" },
        { "include": "#keywords" },
        { "include": "#instructions" },
        { "include": "#variables-as-strings" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "match": "(#|//).*$",
                    "name": "comment.line.rdsl"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b\\d+(\\.\\d+)?\\b",
                    "name": "constant.numeric.rdsl"
                }
            ]
        },
        "symbols": {
            "patterns": [
                {
                    "match": "[\\[\\],=]",
                    "name": "punctuation.separator.rdsl"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(let|for|endfor|in|to|true|false)\\b",
                    "name": "keyword.control.rdsl"
                }
            ]
        },
        "instructions": {
            "patterns": [
                {
                    "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.rdsl"
                        }
                    }
                }
            ]
        },
        "variables-as-strings": {
            "patterns": [
                {
                    "match": "[a-zA-Z_./\\\\][a-zA-Z0-9_./\\\\\\-]*",
                    "name": "string.quoted.other.rdsl"
                }
            ]
        }
    }
}