{
  "name": "rust-sim-dsl-highlighter",
  "displayName": "Rust-Sim-DSL-Highlighter",
  "description": "Highlighting and Inlay Hints for the DSL of Rust-Sim",
  "version": "0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/CaulCaul/rust-sim-dsl-highlighter.git"
  },
  "bugs": {
    "url": "https://github.com/CaulCaul/rust-sim-dsl-highlighter/issues"
  },
  "homepage": "https://github.com/CaulCaul/rust-sim-dsl-highlighter#readme",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rust-sim-dsl-highlighter.helloWorld",
        "title": "Hello World"
      }
    ],
    "languages": [
      {
        "id": "rdsl",
        "extensions": [".rdsl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rdsl",
        "scopeName": "source.rdsl",
        "path": "./syntaxes/rdsl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "RDSL Support",
      "properties": {
        "rdsl.inlayHints.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable parameter name hints for instructions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
